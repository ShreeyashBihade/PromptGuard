{
  "name": "@promptguard/core",
  "version": "0.1.0",
  "private": true,
  "description": "Reusable prompt intelligence core for PromptGuard.",
  "type": "commonjs",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
